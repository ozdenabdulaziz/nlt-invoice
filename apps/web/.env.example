DATABASE_URL="postgresql://<user>:<password>@<host>/<database>?channel_binding=require&connect_timeout=15&sslmode=require"
AUTH_SECRET="replace-with-a-secure-random-secret"
# Note: In Vercel, AUTH_URL and NEXT_PUBLIC_APP_URL should ONLY be set for the Production environment scope.
# Preview deployments will rely on VERCEL_URL automatically.
AUTH_URL="http://localhost:3000"
NEXTAUTH_URL="http://localhost:3000"
NEXT_PUBLIC_APP_URL="http://localhost:3000"
STRIPE_SECRET_KEY="sk_test_replace_me"
STRIPE_WEBHOOK_SECRET="whsec_replace_me"
# Security: if a real Resend key was ever committed, rotate it immediately in the Resend dashboard.
RESEND_API_KEY="re_replace_me"
EMAIL_FROM="NLT Invoice <noreply@mail.nltinvoice.com>"

# Upstash Redis for distributed rate limiting (optional in dev, required in production)
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""
